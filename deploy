#!/usr/bin/env bash
#
# Pilotwave one-shot installer for a single-VM Kubernetes cluster.
#
#   Usage (on the VM, after `git pull`):
#       ./deploy
#
# What it does, in order:
#   1. Preflight  — verify kubectl + a reachable cluster, install Helm/istioctl if missing.
#   2. Istio      — install Istio (the `default` profile: istiod + ingress gateway),
#                   unless an Istio control plane is already running.
#   3. Build      — build the Pilotwave container image FROM SOURCE in this checkout,
#                   so the freshly redesigned UI is what gets deployed.
#   4. Load       — import the image into the cluster's container runtime
#                   (k3s / RKE2 / containerd / microk8s / minikube / kind auto-detected).
#   5. Deploy     — `helm upgrade --install` the chart in build/helm/pilotwave as a
#                   NodePort service.
#   6. Verify     — wait for the rollout and print the access URL.
#
# Everything is overridable with environment variables — see the block below.
# The script is idempotent: re-running it upgrades in place.

set -Eeuo pipefail

# ---------------------------------------------------------------------------
# Configuration (override by exporting before running, e.g. `NODE_PORT=31000 ./deploy`)
# ---------------------------------------------------------------------------
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Image
IMAGE_NAME="${IMAGE_NAME:-pilotwave}"
IMAGE_TAG="${IMAGE_TAG:-local}"
IMAGE_REF="${IMAGE_NAME}:${IMAGE_TAG}"

# Kubernetes / Helm
NAMESPACE="${NAMESPACE:-pilotwave}"
RELEASE="${RELEASE:-pilotwave}"
NODE_PORT="${NODE_PORT:-30080}"          # external port -> http://<node-ip>:NODE_PORT
NODE_IP="${NODE_IP:-10.10.7.209}"        # only used to print the final URL

# Istio. Pilotwave talks to networking.istio.io/v1alpha3 + security.istio.io/v1beta1,
# which Istio 1.20–1.24 still serve. Override ISTIO_VERSION to match your cluster's
# Kubernetes version if needed (e.g. older cluster -> older Istio).
ISTIO_VERSION="${ISTIO_VERSION:-1.22.6}"
ISTIO_PROFILE="${ISTIO_PROFILE:-default}"
INSTALL_ISTIO="${INSTALL_ISTIO:-auto}"   # auto | yes | no

# Auth secret: generated once and cached locally so re-deploys keep sessions valid.
AUTH_SECRET_FILE="${AUTH_SECRET_FILE:-${SCRIPT_DIR}/.deploy/auth-secret}"

# ---------------------------------------------------------------------------
# Pretty logging
# ---------------------------------------------------------------------------
if [ -t 1 ]; then
  C_BLUE=$'\033[1;34m'; C_GREEN=$'\033[1;32m'; C_YELLOW=$'\033[1;33m'
  C_RED=$'\033[1;31m'; C_DIM=$'\033[2m'; C_RST=$'\033[0m'
else
  C_BLUE=""; C_GREEN=""; C_YELLOW=""; C_RED=""; C_DIM=""; C_RST=""
fi
step() { echo; echo "${C_BLUE}==>${C_RST} ${C_BLUE}$*${C_RST}"; }
info() { echo "    $*"; }
ok()   { echo "    ${C_GREEN}✓${C_RST} $*"; }
warn() { echo "    ${C_YELLOW}!${C_RST} $*"; }
die()  { echo "${C_RED}✗ $*${C_RST}" >&2; exit 1; }
trap 'die "deploy failed at line ${LINENO}. See the output above."' ERR

have() { command -v "$1" >/dev/null 2>&1; }

# Run a command with sudo only when not already root and sudo exists.
maybe_sudo() {
  if [ "$(id -u)" -eq 0 ]; then "$@"; elif have sudo; then sudo "$@"; else "$@"; fi
}

# ===========================================================================
# 1. Preflight
# ===========================================================================
step "1/6  Preflight checks"

have kubectl || die "kubectl not found. Install kubectl and ensure it points at your cluster."
if ! kubectl cluster-info >/dev/null 2>&1; then
  die "Cannot reach a Kubernetes cluster via kubectl. Check your kubeconfig / KUBECONFIG."
fi
K8S_VER="$(kubectl version -o json 2>/dev/null | grep -o '\"gitVersion\": *\"v[0-9.]*\"' | head -1 | grep -o 'v[0-9.]*' | tail -1 || true)"
ok "Cluster reachable${K8S_VER:+ (server ${K8S_VER})}"

# Pick a container image builder.
BUILDER=""
for b in docker nerdctl podman; do
  if have "$b"; then BUILDER="$b"; break; fi
done
[ -n "$BUILDER" ] || die "No image builder found. Install one of: docker, nerdctl, podman."
ok "Image builder: ${BUILDER}"

# Helm — install a static binary if missing.
if ! have helm; then
  warn "helm not found — installing the latest Helm 3 release locally"
  curl -fsSL https://raw.githubusercontent.com/helm/helm/main/scripts/get-helm-3 | bash
fi
have helm || die "helm install failed."
ok "helm: $(helm version --short 2>/dev/null || echo present)"

# ===========================================================================
# 2. Istio
# ===========================================================================
step "2/6  Istio ${ISTIO_VERSION} (profile: ${ISTIO_PROFILE})"

istio_present() { kubectl get namespace istio-system >/dev/null 2>&1 && kubectl -n istio-system get deploy istiod >/dev/null 2>&1; }

DO_ISTIO="$INSTALL_ISTIO"
if [ "$DO_ISTIO" = "auto" ]; then
  if istio_present; then DO_ISTIO="no"; else DO_ISTIO="yes"; fi
fi

if [ "$DO_ISTIO" = "no" ]; then
  ok "Istio control plane already present — skipping install (set INSTALL_ISTIO=yes to force)."
else
  ISTIO_HOME="${SCRIPT_DIR}/.deploy/istio-${ISTIO_VERSION}"
  ISTIOCTL="${ISTIO_HOME}/bin/istioctl"
  if [ ! -x "$ISTIOCTL" ]; then
    info "Downloading istioctl ${ISTIO_VERSION}…"
    mkdir -p "${SCRIPT_DIR}/.deploy"
    ( cd "${SCRIPT_DIR}/.deploy" && curl -fsSL https://istio.io/downloadIstio | ISTIO_VERSION="${ISTIO_VERSION}" sh - )
  fi
  [ -x "$ISTIOCTL" ] || die "istioctl ${ISTIO_VERSION} not found after download."
  info "Installing Istio (this can take a couple of minutes)…"
  "$ISTIOCTL" install --set profile="${ISTIO_PROFILE}" -y
  kubectl -n istio-system rollout status deploy/istiod --timeout=180s
  ok "Istio installed."
fi

# Confirm the CRDs Pilotwave needs are present.
for crd in gateways.networking.istio.io virtualservices.networking.istio.io \
           authorizationpolicies.security.istio.io requestauthentications.security.istio.io; do
  kubectl get crd "$crd" >/dev/null 2>&1 || die "Required Istio CRD missing: ${crd}"
done
ok "Istio CRDs verified."

# ===========================================================================
# 3. Build the image from source (carries the redesigned UI)
# ===========================================================================
step "3/6  Building image ${IMAGE_REF} from source"

[ -f "${SCRIPT_DIR}/build/docker/Dockerfile" ] || die "Dockerfile not found — run this from the repo root."
info "Builder: ${BUILDER} (multi-stage: Vite frontend + Go backend → distroless)"
"$BUILDER" build \
  -f "${SCRIPT_DIR}/build/docker/Dockerfile" \
  -t "${IMAGE_REF}" \
  "${SCRIPT_DIR}"
ok "Image built: ${IMAGE_REF}"

# ===========================================================================
# 4. Load the image into the cluster's container runtime
# ===========================================================================
step "4/6  Importing image into the cluster runtime"

import_via_tar() {
  # $1 = import command (array passed as remaining args reads from stdin tar)
  local tar="/tmp/${IMAGE_NAME}-${IMAGE_TAG}.tar"
  info "Saving image to ${tar}…"
  "$BUILDER" save "${IMAGE_REF}" -o "$tar"
  "$@" < "$tar"
  rm -f "$tar"
}

loaded=""
if have k3s; then
  info "Detected k3s — importing into k3s containerd."
  import_via_tar maybe_sudo k3s ctr images import -
  loaded="k3s"
elif have rke2; then
  info "Detected RKE2 — importing into rke2 containerd."
  import_via_tar maybe_sudo rke2 ctr images import -
  loaded="rke2"
elif have microk8s; then
  info "Detected microk8s — importing image."
  import_via_tar microk8s ctr images import -
  loaded="microk8s"
elif have minikube && minikube status >/dev/null 2>&1; then
  info "Detected minikube — loading image."
  minikube image load "${IMAGE_REF}"
  loaded="minikube"
elif have kind && [ -n "$(kind get clusters 2>/dev/null)" ]; then
  info "Detected kind — loading image into cluster '$(kind get clusters | head -1)'."
  kind load docker-image "${IMAGE_REF}" --name "$(kind get clusters | head -1)"
  loaded="kind"
elif have ctr; then
  info "Detected containerd (ctr) — importing into the k8s.io namespace."
  import_via_tar maybe_sudo ctr -n k8s.io images import -
  loaded="containerd"
elif [ "$BUILDER" = "docker" ] && have crictl && crictl info 2>/dev/null | grep -qi docker; then
  loaded="docker-runtime"
fi

if [ -n "$loaded" ]; then
  ok "Image available to the cluster (${loaded})."
else
  warn "Could not auto-detect the cluster container runtime."
  warn "The image '${IMAGE_REF}' was built locally but may not be visible to the cluster."
  warn "If pods stay in ImagePullBackOff, import it manually, e.g.:"
  warn "    ${BUILDER} save ${IMAGE_REF} | sudo ctr -n k8s.io images import -"
fi

# ===========================================================================
# 5. Deploy with Helm (NodePort)
# ===========================================================================
step "5/6  Deploying with Helm"

# Stable auth secret: generate once, reuse on subsequent deploys.
if [ ! -f "$AUTH_SECRET_FILE" ]; then
  mkdir -p "$(dirname "$AUTH_SECRET_FILE")"
  if have openssl; then openssl rand -hex 24 > "$AUTH_SECRET_FILE"
  else head -c 24 /dev/urandom | od -An -tx1 | tr -d ' \n' > "$AUTH_SECRET_FILE"; fi
  chmod 600 "$AUTH_SECRET_FILE"
  info "Generated a new auth secret (cached at ${AUTH_SECRET_FILE})."
fi
AUTH_SECRET="$(cat "$AUTH_SECRET_FILE")"

info "Release '${RELEASE}' in namespace '${NAMESPACE}', NodePort ${NODE_PORT}."
helm upgrade --install "${RELEASE}" "${SCRIPT_DIR}/build/helm/pilotwave" \
  --namespace "${NAMESPACE}" --create-namespace \
  --set image.repository="${IMAGE_NAME}" \
  --set image.tag="${IMAGE_TAG}" \
  --set image.pullPolicy=IfNotPresent \
  --set service.type=NodePort \
  --set service.nodePort="${NODE_PORT}" \
  --set-string auth.secret.value="${AUTH_SECRET}" \
  --wait --timeout 5m
ok "Helm release applied."

# ===========================================================================
# 6. Verify
# ===========================================================================
step "6/6  Waiting for Pilotwave to become ready"

kubectl -n "${NAMESPACE}" rollout status deploy --timeout=180s || true
ACTUAL_PORT="$(kubectl -n "${NAMESPACE}" get svc -l app.kubernetes.io/instance="${RELEASE}" \
  -o jsonpath='{.items[0].spec.ports[0].nodePort}' 2>/dev/null || echo "${NODE_PORT}")"
[ -n "$ACTUAL_PORT" ] || ACTUAL_PORT="${NODE_PORT}"

echo
echo "${C_GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${C_RST}"
echo "${C_GREEN}  Pilotwave is deployed.${C_RST}"
echo
echo "    URL:       ${C_BLUE}http://${NODE_IP}:${ACTUAL_PORT}${C_RST}"
echo "    Login:     admin / admin   ${C_DIM}(change it after first login)${C_RST}"
echo "    Namespace: ${NAMESPACE}"
echo
echo "    ${C_DIM}Pods:    kubectl -n ${NAMESPACE} get pods${C_RST}"
echo "    ${C_DIM}Logs:    kubectl -n ${NAMESPACE} logs deploy/${RELEASE} -f${C_RST}"
echo "    ${C_DIM}Remove:  helm -n ${NAMESPACE} uninstall ${RELEASE}${C_RST}"
echo "${C_GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${C_RST}"
